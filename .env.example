# --- Primary backend: Google Gemini ---------------------------------------
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# --- Optional alternative backend: Anthropic Claude -----------------------
# ANTHROPIC_API_KEY=sk-ant-...

# Without any key the benchmark falls back to the offline 'reference' oracle.

# --- Optional overrides ----------------------------------------------------
# MATHBENCH_BACKEND=gemini             # force a backend: gemini | claude | reference
# MATHBENCH_MODEL=gemini-2.5-flash     # override the model for the active backend
# MATHBENCH_GEMINI_MODEL=gemini-2.5-pro
# MATHBENCH_CLAUDE_MODEL=claude-sonnet-4-20250514
